marks = []

print("Enter marks for 5 subjects:")

for i in range(5):
    m = int(input(f"Subject {i+1}: "))
    marks.append(m)

total = sum(marks)
average = total / 5

# Grade calculation
if average >= 90:
    grade = 'A'
elif average >= 75:
    grade = 'B'
elif average >= 60:
    grade = 'C'
elif average >= 40:
    grade = 'D'
else:
    grade = 'F'

print("\nTotal Marks =", total)
print("Average =", average)
print("Grade =", grade)
