n = int(input("Enter number of elements: "))

nums = []

for i in range(n):
    val = int(input("Enter number: "))
    nums.append(val)

largest = second = -999999

for num in nums:
    if num > largest:
        second = largest
        largest = num
    elif num > second and num != largest:
        second = num

print("Second largest number is:", second)
