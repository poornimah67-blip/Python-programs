# Student Grade Calculator

# Input marks
m1 = int(input("Enter marks of subject 1: "))
m2 = int(input("Enter marks of subject 2: "))
m3 = int(input("Enter marks of subject 3: "))

# Calculate total and average
total = m1 + m2 + m3
average = total / 3

# Display results
print("Total =", total)
print("Average =", round(average, 2))

# Grade calculation
if average >= 90:
    print("Grade: A")
elif average >= 75:
    print("Grade: B")
elif average >= 50:
    print("Grade: C")
else:
    print("Grade: Fail")
